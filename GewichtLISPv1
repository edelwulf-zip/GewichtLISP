(defun c:G ( / sset idx ename obj vol density volCm3 weightKg pt txtObj textStr cDoc space)
  (vl-load-com)
  
  ;; 1. Get density input from the user
  (setq density (getreal "\nEnter material density in g/cm³: "))
  
  (if density
    (progn
      (princ "\nSelect 3D Solids to calculate weight: ")
      ;; 2. Prompt user to select 3D solids
      (if (setq sset (ssget '((0 . "3DSOLID"))))
        (progn
          (setq cDoc (vla-get-ActiveDocument (vlax-get-acad-object)))
          (setq space (if (= (getvar "CVPORT") 1)
                        (vla-get-PaperSpace cDoc)
                        (vla-get-ModelSpace cDoc)))
          
          (setq idx 0)
          ;; Loop through all selected solids
          (while (< idx (sslength sset))
            (setq ename (ssname sset idx))
            (setq obj (vlax-ename->vla-object ename))
            
            ;; Get raw volume (assumed to be in cubic millimeters, mm³)
            (setq vol (vla-get-Volume obj))
            
            ;; CONVERSION LOGIC (Assumes drawing is in mm):
            ;; Convert mm³ to cm³ by dividing by 1,000
            (setq volCm3 (/ vol 1000.0))
            
            ;; Calculate weight in grams (cm³ * g/cm³)
            ;; Then divide by 1,000 to convert grams to kilograms (kg)
            (setq weightKg (/ (* volCm3 density) 1000.0))
            
            ;; Format the text string (3 decimal places)
            (setq textStr (strcat "Weight: " (rtos weightKg 2 2 2) " kg"))
            
            ;; Highlight the current solid
            (redraw ename 3)
            
            ;; Ask user where to place the text
            (setq pt (getpoint "\nPick insertion point for weight text: "))
            
            ;; Unhighlight the solid
            (redraw ename 4)
            
            (if pt
              (progn
                ;; Create MText at the picked point
                (setq txtObj (vla-addMText space (vlax-3d-point pt) 0.0 textStr))
                (vla-put-AttachmentPoint txtObj 1) ;; Top-Left alignment
              )
            )
            (setq idx (1+ idx))
          )
        )
        (princ "\nNo 3D Solids selected.")
      )
    )
    (princ "\nInvalid density input.")
  )
  (princ)
)

(princ "\nType 'SolWeightText' to run the routine.")
(princ)
